flowchart TD
      subgraph L2["Layer 2: Server Ingest + Per-Batch Analysis"]
          RECV["POST /ingest<br>batch received"]
          SAVE["Save frames<br>→ frames_dir/{session}/{batch}/"]

          RECV --> SAVE
          SAVE --> CTX["Load prior context<br>(session continuity)"]
          CTX --> BUILD["Build VLM input<br>preamble: duration, frame
  count, prior summary<br>per-frame: index, Δt, motion_state,
  speech_detected, noise_level"]
          BUILD --> CALL["Call VLM<br>model · prompt<br>max_tokens=512"]
          CALL --> VALID{"JSON valid?"}
          VALID -- "No (retry ≤ 2×)" --> CALL
          VALID -- "Failed all retries" --> ERR["Log error<br>skip memory
  write"]
          VALID -- "Yes" --> SCTX["Save summary<br>→ prior context"]
          SCTX --> WLOG["Append to<br>physical-logs/YYYY-MM-DD.md"]
          WLOG --> RESP["Return summary to iOS"]
          RESP --> CHK{"insight_min_batches reached<br>OR
  insight_min_minutes elapsed?"}
          CHK -- "No" --> DONE1((" "))
          CHK -- "Yes" --> SPAWN["Spawn insight update<br>(background
  thread)"]
      end

      subgraph L3["Layer 3: OpenClaw Memory"]
          subgraph INS["Rolling Daily Insight"]
              READ["Read physical-logs/YYYY-MM-DD.md<br>(new entries since last
   offset)"]
              LOAD_I["Load existing<br>physical-insights/YYYY-MM-DD.md"]
              CMTS["Consume pending_comments<br>→ clear file"]
              READ --> MERGE["Merge: existing insight<br>+ new log
  entries<br>+ human annotations"]
              LOAD_I --> MERGE
              CMTS --> MERGE
              MERGE --> IVLM["Call VLM<br>model ·
  insight_prompt<br>max_tokens=1024"]
              IVLM --> WINS["Write physical-insights/YYYY-MM-DD.md<br>Update
  log offset"]
          end

          subgraph PAT["Nightly Pattern Update"]
              SCHED["Scheduler<br>(checks every 10 min)"]
              SCHED --> NHOUR{"now.hour == nightly_hour?"}
              NHOUR -- "No" --> SCHED
              NHOUR -- "Yes (once per day)" --> LOAD_P["Load yesterday's
  insight<br>(+ today's partial if nightly_hour < 12)<br>+ existing
  physical-pattern.md"]
              LOAD_P --> PVLM["Call VLM<br>model ·
  pattern_prompt<br>max_tokens=2048"]
              PVLM --> WPAT["Write physical-pattern.md"]
          end
      end

      subgraph CMT["Human Annotation"]
          COMMENT["POST /api/comment"]
          COMMENT --> PEND["Append to pending_comments.jsonl"]
          COMMENT --> ARCH["Append
  to<br>openclaw_memory_dir/human-comments.md"]
      end

      SPAWN --> READ
      PEND -. "consumed at next<br>insight trigger" .-> CMTS
      WINS -. "Feed-in into" .-> LOAD_P