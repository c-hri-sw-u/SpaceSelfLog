# Copy to .env and fill in your values

# Required — get from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-...

# Path to OpenClaw's memory/ directory
# e.g. /Users/you/Documents/GitHub/openclaw/memory
OPENCLAW_MEMORY_DIR=

# Optional
PORT=8000
VLM_MODEL=anthropic/claude-sonnet-4-6
FRAMES_DIR=~/.spaceselflog/frames
CONTEXT_FILE=~/.spaceselflog/context.json
