flowchart LR
    %%{init: {
        'theme': 'neutral', 
        'themeVariables': { 
            'fontSize': '30px',
            'primaryBorderColor': '#111',
            'clusterBndry': '#111'
        },
        'flowchart': { 'nodeSpacing': 50, 'rankSpacing': 100 }
    }}%%

    Start([Start]) --> A[AGENTS.md]
    A -- "Guided Load" --> Workspace

    subgraph Workspace ["Core Context"]
        direction TB
        Files[SOUL, IDENTITY, USER.md<br/>SKILLS, TOOLS.md]
        Rules[Memory Path & Rules]
    end

    Workspace --> Build([Assemble])
    Build --> Session{{<b><span style='font-size:40px'>Active Session</span></b>}}

    Session --> Query[LLM Reasoning]
    Query --> Dec{Need Memory?}
    Dec -- Yes --> Search[memory_search]
    Search -.-> |Consult| Rules
    Search --> Query
    Dec -- No --> Response[Respond]
    Response --> Session

    %% Global line and border thickness
    linkStyle default stroke:#111,stroke-width:4px
    classDef thickNode stroke-width:4px
    class A,Files,Rules,Build,Session,Query,Dec,Search,Response thickNode

    style Workspace fill:none,stroke:#111,stroke-width:4px,stroke-dasharray: 10 10
